package templates

import "fmt"

templ ErrorPage(code int, message string) {
    @Layout(fmt.Sprintf("%d", code)){
        <div class="grid">
            <hgroup class="error">
                <h1 class="pico-color-red-550">{ fmt.Sprintf("Error %d", code) }</h1>
                <h3>{ message }</h3>
            </hgroup>
        </div>
    }
}